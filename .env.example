# Close API Configuration
# Copy this file to .env and fill in your actual values

# Your Close API Key (required)
API_KEY=your_api_key_here

# Path to the MOCK_DATA.csv file (required)
FILE=mock_data.csv

# Start date for filtering (YYYY-MM-DD) (required)
START_DATE=1978-01-01

# End date for filtering (YYYY-MM-DD) (required)
END_DATE=2024-12-31

# Output CSV filename (optional, defaults to state_segments.csv)
OUTPUT=state_segments.csv
